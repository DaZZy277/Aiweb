<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Center Item on Website</title>
<style>
  body, html {
    height: 100%;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .centered-item {
    width: 200px;
    height: 200px;
    background-color: #f0f0f0;
    text-align: center;
    line-height: 200px; /* Align text vertically */
  }
</style>
</head>
<body>
  <div class="centered-item">
    <p>Centered Content</p>
  </div>
</body>
</html>
