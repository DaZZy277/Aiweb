<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="css/style.css" rel="stylesheet" />
    <title>Document</title>
</head>
<body>
    <form method="post" action="/login" >
        <% Object.values(output).forEach(function(item){ %>
            <div class = "background">
    
                <div class="container">   
                    <form  method="post" class="fromData" action="">
                        <div class = "objcontain 1">
                            <p>result of money</p>
                            <input type="number" id="money-input" name="money_input" value="<%= item.resultMoney %>">
                        </div>  
                        
                        
                        <div class = "objcontain 2">
                            
                            <label for = "Percentage-input">
                            <input type="float" id="Percentage-input" name="Percentage_input_Manual" value="<%= item.resultPercentage %>"> </label>
                            <div class="percent">%</div>

                        </div>
                        
                        <div class = "objcontain 3">
                            <button type="submit" id = "submit button"> Save </button>
                        </div>
            
                    </form>
                    
                </div>
            </div>
        <% }) %>
    </form>
</body>
</html>